{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "ignoreDeprecations": "6.0",
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
